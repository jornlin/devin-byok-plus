{
  "name": "windsurf-byok-bridge",
  "displayName": "Windsurf BYOK Bridge",
  "description": "Windsurf BYOK 桥接 — 本地 API Key，多模型路由",
  "version": "1.0.0",
  "publisher": "ycx932436",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ycx932436/windsurf-byok-bridge.git"
  },
  "homepage": "https://github.com/ycx932436/windsurf-byok-bridge",
  "bugs": {
    "url": "https://github.com/ycx932436/windsurf-byok-bridge/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:windsurf-byok-bridge.sidebar"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "windsurf-byok-bridge",
          "title": "Windsurf BYOK Bridge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "windsurf-byok-bridge": [
        {
          "type": "webview",
          "id": "windsurf-byok-bridge.sidebar",
          "name": "控制面板",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "windsurf-byok-bridge.startProxy",
        "title": "Windsurf BYOK Bridge: 启动代理"
      },
      {
        "command": "windsurf-byok-bridge.stopProxy",
        "title": "Windsurf BYOK Bridge: 停止代理"
      },
      {
        "command": "windsurf-byok-bridge.applyPatch",
        "title": "Windsurf BYOK Bridge: 安装补丁"
      },
      {
        "command": "windsurf-byok-bridge.revertPatch",
        "title": "Windsurf BYOK Bridge: 还原补丁"
      },
      {
        "command": "windsurf-byok-bridge.reloadWorkbench",
        "title": "Windsurf BYOK Bridge: 重载窗口（补丁生效）"
      }
    ]
  }
}
